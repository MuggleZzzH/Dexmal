<?xml version="1.0"?>
<robot name="six_axis_arm">
    
    <!-- Base Link -->
    <link name="base_link">
        <visual>
            <geometry>
                <cylinder length="0.2" radius="0.15"/>
            </geometry>
            <material name="base_material">
                <color rgba="0.2 0.2 0.8 1.0"/>
            </material>
        </visual>
    </link>
    
    <!-- Link 1 -->
    <link name="link1">
        <visual>
            <origin xyz="0 0 0.15" rpy="0 0 0"/>
            <geometry>
                <cylinder length="0.3" radius="0.08"/>
            </geometry>
            <material name="link1_material">
                <color rgba="0.8 0.2 0.2 1.0"/>
            </material>
        </visual>
    </link>
    
    <!-- Link 2 -->
    <link name="link2">
        <visual>
            <origin xyz="0 0 0.2" rpy="0 0 0"/>
            <geometry>
                <cylinder length="0.4" radius="0.06"/>
            </geometry>
            <material name="link2_material">
                <color rgba="0.2 0.8 0.2 1.0"/>
            </material>
        </visual>
    </link>
    
    <!-- Link 3 -->
    <link name="link3">
        <visual>
            <origin xyz="0 0 0.15" rpy="0 0 0"/>
            <geometry>
                <cylinder length="0.3" radius="0.05"/>
            </geometry>
            <material name="link3_material">
                <color rgba="0.8 0.8 0.2 1.0"/>
            </material>
        </visual>
    </link>
    
    <!-- Link 4 -->
    <link name="link4">
        <visual>
            <origin xyz="0 0 0.125" rpy="0 0 0"/>
            <geometry>
                <cylinder length="0.25" radius="0.04"/>
            </geometry>
            <material name="link4_material">
                <color rgba="0.8 0.2 0.8 1.0"/>
            </material>
        </visual>
    </link>
    
    <!-- Link 5 -->
    <link name="link5">
        <visual>
            <origin xyz="0 0 0.1" rpy="0 0 0"/>
            <geometry>
                <cylinder length="0.2" radius="0.035"/>
            </geometry>
            <material name="link5_material">
                <color rgba="0.2 0.8 0.8 1.0"/>
            </material>
        </visual>
    </link>
    
    <!-- End Effector -->
    <link name="end_effector">
        <visual>
            <geometry>
                <box size="0.1 0.1 0.1"/>
            </geometry>
            <material name="ee_material">
                <color rgba="0.9 0.9 0.9 1.0"/>
            </material>
        </visual>
    </link>
    
    <!-- Base Joint (旋转底座) -->
    <joint name="base_joint" type="revolute">
        <parent link="base_link"/>
        <child link="link1"/>
        <origin xyz="0 0 0.1" rpy="0 0 0"/>
        <axis xyz="0 0 1"/>
        <limit lower="-3.14159" upper="3.14159" effort="100" velocity="1"/>
    </joint>
    
    <!-- Shoulder Joint (肩关节) -->
    <joint name="shoulder_joint" type="revolute">
        <parent link="link1"/>
        <child link="link2"/>
        <origin xyz="0 0 0.3" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <limit lower="-1.57079" upper="1.57079" effort="100" velocity="1"/>
    </joint>
    
    <!-- Elbow Joint (肘关节) -->
    <joint name="elbow_joint" type="revolute">
        <parent link="link2"/>
        <child link="link3"/>
        <origin xyz="0 0 0.4" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <limit lower="-2.35619" upper="2.35619" effort="100" velocity="1"/>
    </joint>
    
    <!-- Wrist 1 Joint (腕关节1) -->
    <joint name="wrist1_joint" type="revolute">
        <parent link="link3"/>
        <child link="link4"/>
        <origin xyz="0 0 0.3" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
        <limit lower="-1.57079" upper="1.57079" effort="100" velocity="1"/>
    </joint>
    
    <!-- Wrist 2 Joint (腕关节2) -->
    <joint name="wrist2_joint" type="revolute">
        <parent link="link4"/>
        <child link="link5"/>
        <origin xyz="0 0 0.25" rpy="0 0 0"/>
        <axis xyz="1 0 0"/>
        <limit lower="-1.57079" upper="1.57079" effort="100" velocity="1"/>
    </joint>
    
    <!-- Wrist 3 Joint (腕关节3) -->
    <joint name="wrist3_joint" type="revolute">
        <parent link="link5"/>
        <child link="end_effector"/>
        <origin xyz="0 0 0.2" rpy="0 0 0"/>
        <axis xyz="0 0 1"/>
        <limit lower="-3.14159" upper="3.14159" effort="100" velocity="1"/>
    </joint>
    
</robot>
