<?xml version="1.0"?>
<launch>
  <!-- Load robot description from URDF -->
  <param name="robot_description" command="$(find xacro)/xacro $(find replay)/urdf/replay.urdf" />

  <!-- Start robot state publisher -->
  <node name="robot_state_publisher" pkg="robot_state_publisher" type="robot_state_publisher" />

  <!-- Start joint state publisher GUI -->
  <node name="joint_state_publisher_gui" pkg="joint_state_publisher_gui" type="joint_state_publisher_gui" />

  <!-- Start RViz with custom config -->
  <node name="rviz" pkg="rviz" type="rviz" args="-d $(find replay)/config/view_robot.rviz" />
</launch>
